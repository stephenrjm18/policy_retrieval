

# ── Ollama endpoint ────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434

# ── Model assignments ──────────────────────────────────────────
# Lightweight model for semantic routing (fast, <1B params recommended)
ROUTER_MODEL=qwen2.5:1.5b

# Lightweight model for intent extraction (shared with router by default)
INTENT_MODEL=qwen2.5:1.5b

# Model for SQL generation fallback (code-focused model preferred)
SQL_MODEL=qwen2.5-coder:7b

# Main model for RAG answer generation
RAG_MODEL=qwen2.5:3b

# ── Retrieval tuning ───────────────────────────────────────────
RAG_TOP_K_DENSE=10      # Dense retrieval candidates
RAG_TOP_K_SPARSE=10     # BM25 retrieval candidates
RAG_TOP_K_RERANK=5      # Final chunks after reranking

# ── Semantic cache ─────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_MAX_ENTRIES=500
CACHE_SIM_THRESH=0.92   # Cosine similarity threshold (0–1)

# ── Reranker ───────────────────────────────────────────────────
RERANKER_ENABLED=true   # Set false to skip cross-encoder reranking

# ── Server ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
SECRET_KEY=change-me-in-production
